APP_NAME=backend-rag-multipurpose
APP_HOST=0.0.0.0
APP_PORT=9010
HOST_APP_PORT=9010
LOG_LEVEL=INFO

POSTGRES_DSN=postgresql://postgres:postgres@localhost:5432/ragdb
POSTGRES_MIN_POOL_SIZE=1
POSTGRES_MAX_POOL_SIZE=10

REDIS_URL=redis://localhost:6379/0
REDIS_MAX_CONNECTIONS=10

OPENAI_ENABLED=false
OPENAI_API_KEY=

GEMINI_ENABLED=false
GEMINI_API_KEY=

OLLAMA_ENABLED=true
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_HEALTH_TIMEOUT_SECONDS=3.0

DEFAULT_LLM_PROVIDER=ollama
DEFAULT_LLM_MODEL=llama3.2
DEFAULT_EMBEDDING_PROVIDER=ollama
DEFAULT_EMBEDDING_MODEL=qwen3-embedding
CANONICAL_EMBEDDING_DIMENSION=4096
CHUNK_SIZE=1000
CHUNK_OVERLAP=150
STRUCTURED_ROWS_PER_CHUNK=10
SIMILARITY_THRESHOLD=0.35
MAX_SESSION_MESSAGES=12

CHAT_RATE_LIMIT_REQUESTS=30
CHAT_RATE_LIMIT_WINDOW_SECONDS=60
RETRIEVAL_CACHE_TTL_SECONDS=120
EMBEDDING_CACHE_TTL_SECONDS=3600
SESSION_TTL_SECONDS=1800
SESSION_STORAGE_ENABLED=false
AUTH_ENABLED=true
AUTH_JWT_SECRET=change-me-immediately
AUTH_JWT_ALGORITHM=HS256
AUTH_ACCESS_TOKEN_TTL_SECONDS=3600
AUTH_BOOTSTRAP_ADMIN_USERNAME=admin
AUTH_BOOTSTRAP_ADMIN_PASSWORD=change-me-immediately
AUTH_REQUIRE_HTTPS=false
